# Encryption (REQUIRED for encrypted mode)
MONIKA_SHARED_SECRET=your-32-char-minimum-secret-key
MONIKA_NONCE_SIZE=12
MONIKA_CIPHER_TYPE=aes256gcm
ENABLE_ENCRYPTION=1

# Server config
SERVER_HOST=127.0.0.1
SERVER_PORT=12345

# Ollama config
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_NUM_PREDICT=280
OLLAMA_NUM_CTX=4096
OLLAMA_HEARTBEAT_SECS=60
OLLAMA_WARMUP=1

# Unity Bridge config (client)
UNITY_BRIDGE_HOST=127.0.0.1
UNITY_BRIDGE_PORT=12346

# Client socket timeout
CLIENT_SOCKET_TIMEOUT_SECS=310

# Enable TTS
ENABLE_TTS=1
